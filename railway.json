{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "corepack enable && corepack prepare pnpm@10.30.3 --activate && pnpm install --frozen-lockfile && pnpm --filter web build",
    "watchPatterns": [
      "/apps/web/**",
      "/packages/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "PORT=${PORT:-3000} node apps/web/node_modules/next/dist/bin/next start apps/web -H 0.0.0.0 -p ${PORT:-3000}",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
